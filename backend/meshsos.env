# MeshSOS runtime configuration for systemd services.
# Copy to /opt/meshsos/backend/meshsos.env on the Raspberry Pi and edit values as needed.

# Meshtastic bridge serial configuration
MESHSOS_BRIDGE_SERIAL_PORT=/dev/ttyACM0
MESHSOS_BRIDGE_BAUDRATE=115200

# FastAPI bind settings
MESHSOS_API_HOST=0.0.0.0
MESHSOS_API_PORT=8000
